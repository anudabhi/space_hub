<% content_for :title, "Edit Profile — SpaceHub" %>

<div class="container py-5" style="max-width:560px;">
  <h2 class="fw-bold mb-1">Edit Profile</h2>
  <p class="text-muted mb-4 small">Update your account details below.</p>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <h6 class="fw-semibold mb-3">Profile</h6>
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-3">
          <%= f.label :name, class: "form-label fw-semibold" %>
          <%= f.text_field :name, class: "form-control", autocomplete: "name" %>
        </div>
        <div class="mb-3">
          <%= f.label :email, class: "form-label fw-semibold" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="form-text text-warning">Waiting confirmation for: <%= resource.unconfirmed_email %></div>
          <% end %>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <%= f.label :phone, class: "form-label fw-semibold" %>
            <%= f.text_field :phone, class: "form-control", placeholder: "+91 98765 43210" %>
          </div>
          <div class="col-md-6">
            <%= f.label :city, class: "form-label fw-semibold" %>
            <%= f.select :city, options_for_select([""] + Listing::CITIES, resource.city), {}, class: "form-select" %>
          </div>
        </div>
        <div class="mb-3">
          <%= f.label :bio, class: "form-label fw-semibold" %>
          <%= f.text_area :bio, rows: 3, class: "form-control", placeholder: "A short bio visible on your listings..." %>
        </div>
        <div class="mb-4">
          <%= f.label :avatar, "Profile Photo", class: "form-label fw-semibold" %>
          <%= f.file_field :avatar, accept: "image/*", class: "form-control" %>
        </div>

        <h6 class="fw-semibold mb-3 mt-4 pt-3 border-top">Change Password</h6>
        <div class="mb-3">
          <%= f.label :password, class: "form-label fw-semibold" %>
          <span class="text-muted small ms-1">(leave blank to keep current)</span>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          <% if @minimum_password_length %>
            <div class="form-text"><%= @minimum_password_length %> characters minimum</div>
          <% end %>
        </div>
        <div class="mb-3">
          <%= f.label :password_confirmation, class: "form-label fw-semibold" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>
        <div class="mb-4">
          <%= f.label :current_password, class: "form-label fw-semibold" %>
          <span class="text-muted small ms-1">(required to save any changes)</span>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
        </div>

        <%= f.submit "Save Changes", class: "btn btn-warning fw-semibold px-4" %>
      <% end %>
    </div>
  </div>

  <div class="card border-danger">
    <div class="card-body p-4">
      <h6 class="fw-semibold text-danger mb-1">Danger Zone</h6>
      <p class="text-muted small mb-3">Permanently delete your account and all associated data.</p>
      <%= button_to "Delete My Account", registration_path(resource_name),
            data: { turbo_confirm: "Are you sure? This cannot be undone." },
            method: :delete,
            class: "btn btn-outline-danger btn-sm" %>
    </div>
  </div>
</div>
