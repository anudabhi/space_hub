<h2>New Booking Request</h2>
<p>Hi <%= @host.display_name %>,</p>
<p><strong><%= @guest.display_name %></strong> has requested to book <strong><%= @listing.title %></strong>.</p>
<ul>
  <li><strong>Date:</strong> <%= @booking.start_time.strftime("%d %b %Y") %></li>
  <li><strong>Time:</strong> <%= @booking.start_time.strftime("%I:%M %p") %> – <%= @booking.end_time.strftime("%I:%M %p") %></li>
  <li><strong>Duration:</strong> <%= @booking.hours_duration %> hours</li>
  <li><strong>Total:</strong> ₹<%= number_with_delimiter(@booking.total_price.to_i) %></li>
</ul>
<p><a href="<%= confirm_host_booking_url(@booking) %>">Review & Confirm Booking</a></p>
