<h2>Booking Confirmed!</h2>
<p>Hi <%= @guest.display_name %>,</p>
<p>Great news! Your booking at <strong><%= @listing.title %></strong> is confirmed.</p>
<ul>
  <li><strong>Date:</strong> <%= @booking.start_time.strftime("%d %b %Y") %></li>
  <li><strong>Time:</strong> <%= @booking.start_time.strftime("%I:%M %p") %> – <%= @booking.end_time.strftime("%I:%M %p") %></li>
  <li><strong>Address:</strong> <%= @listing.address %>, <%= @listing.city %></li>
</ul>
<p><a href="<%= guest_booking_url(@booking) %>">View Booking Details</a></p>
