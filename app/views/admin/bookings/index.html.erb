<% content_for :title, "Bookings — Admin" %>

<div class="container py-4">
  <h2 class="fw-bold mb-4">Bookings</h2>

  <div class="table-responsive">
    <table class="table align-middle">
      <thead class="table-light">
        <tr>
          <th>#</th><th>Guest</th><th>Space</th><th>Date</th><th>Duration</th><th>Amount</th><th>Gateway</th><th>Status</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% @bookings.each do |booking| %>
          <tr>
            <td class="text-muted small">#<%= booking.id %></td>
            <td class="small fw-semibold"><%= booking.user.display_name %></td>
            <td class="small"><%= booking.listing.title.truncate(25) %></td>
            <td class="small text-muted"><%= booking.start_time.strftime("%d %b %Y") %></td>
            <td class="small"><%= booking.hours_duration %>hr</td>
            <td class="small fw-bold">₹<%= number_with_delimiter(booking.total_price.to_i) %></td>
            <td class="small text-capitalize"><%= booking.payment_gateway.presence || "—" %></td>
            <td>
              <span class="badge bg-<%= booking.status == 'confirmed' ? 'success' : booking.status == 'pending' ? 'warning text-dark' : booking.status == 'cancelled' ? 'danger' : 'secondary' %>">
                <%= booking.status.capitalize %>
              </span>
            </td>
            <td>
              <%= link_to "View", admin_booking_path(booking), class: "btn btn-outline-secondary btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-3 d-flex justify-content-center">
    <%== pagy_bootstrap_nav(@pagy) %>
  </div>
</div>
