<% content_for :title, "Listings — Admin" %>

<div class="container py-4">
  <h2 class="fw-bold mb-4">Listings</h2>

  <div class="table-responsive">
    <table class="table align-middle">
      <thead class="table-light">
        <tr>
          <th>Title</th><th>Host</th><th>Category</th><th>City</th><th>Price/hr</th><th>Status</th><th>Rating</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% @listings.each do |listing| %>
          <tr>
            <td class="fw-semibold"><%= listing.title.truncate(30) %></td>
            <td class="small text-muted"><%= listing.user.display_name %></td>
            <td><span class="badge bg-secondary text-capitalize"><%= listing.category %></span></td>
            <td class="small"><%= listing.city %></td>
            <td class="small">₹<%= number_with_delimiter(listing.price_per_hour.to_i) %></td>
            <td>
              <span class="badge bg-<%= listing.status == 'active' ? 'success' : 'secondary' %>">
                <%= listing.status %>
              </span>
            </td>
            <td class="small"><%= listing.avg_rating.to_f > 0 ? "★ #{listing.avg_rating}" : "—" %></td>
            <td class="text-end">
              <%= link_to "View", admin_listing_path(listing), class: "btn btn-outline-secondary btn-sm me-1" %>
              <%= link_to "Delete", admin_listing_path(listing),
                    data: { turbo_method: :delete, turbo_confirm: "Delete this listing?" },
                    class: "btn btn-outline-danger btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-3 d-flex justify-content-center">
    <%== pagy_bootstrap_nav(@pagy) %>
  </div>
</div>
