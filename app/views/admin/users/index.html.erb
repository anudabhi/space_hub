<% content_for :title, "Users — Admin" %>

<div class="container py-4">
  <h2 class="fw-bold mb-4">Users</h2>

  <div class="table-responsive">
    <table class="table align-middle">
      <thead class="table-light">
        <tr>
          <th>Name</th><th>Email</th><th>Role</th><th>City</th><th>Joined</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td class="fw-semibold"><%= user.display_name %></td>
            <td class="text-muted small"><%= user.email %></td>
            <td>
              <span class="badge bg-<%= user.role == 'admin' ? 'danger' : user.role == 'host' ? 'warning text-dark' : 'secondary' %>">
                <%= user.role %>
              </span>
            </td>
            <td class="small"><%= user.city.presence || "—" %></td>
            <td class="small text-muted"><%= user.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end">
              <%= link_to "Edit", edit_admin_user_path(user), class: "btn btn-outline-secondary btn-sm me-1" %>
              <%= link_to "Delete", admin_user_path(user),
                    data: { turbo_method: :delete, turbo_confirm: "Delete #{user.display_name}?" },
                    class: "btn btn-outline-danger btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-3 d-flex justify-content-center">
    <%== pagy_bootstrap_nav(@pagy) %>
  </div>
</div>
