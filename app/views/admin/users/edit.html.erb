<% content_for :title, "Edit #{@user.display_name} — Admin" %>

<div class="container py-4" style="max-width:520px;">
  <div class="mb-3">
    <%= link_to "← Back", admin_user_path(@user), class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <h2 class="fw-bold mb-4">Edit User</h2>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <%= form_with model: [:admin, @user] do |f| %>
        <%= render "shared/errors", resource: @user %>

        <div class="mb-3">
          <%= f.label :name, class: "form-label fw-semibold" %>
          <%= f.text_field :name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :email, class: "form-label fw-semibold" %>
          <%= f.email_field :email, class: "form-control" %>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <%= f.label :role, class: "form-label fw-semibold" %>
            <%= f.select :role, User::ROLES.map { |r| [r.capitalize, r] }, {}, class: "form-select" %>
          </div>
          <div class="col-md-6">
            <%= f.label :city, class: "form-label fw-semibold" %>
            <%= f.select :city, options_for_select([""] + Listing::CITIES, @user.city), {}, class: "form-select" %>
          </div>
        </div>
        <div class="mb-4 form-check">
          <%= f.check_box :host_approved, class: "form-check-input" %>
          <%= f.label :host_approved, "Host approved", class: "form-check-label" %>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit "Save", class: "btn btn-warning fw-semibold px-4" %>
          <%= link_to "Cancel", admin_user_path(@user), class: "btn btn-outline-secondary px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
