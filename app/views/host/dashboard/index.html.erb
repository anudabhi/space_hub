<% content_for :title, "Host Dashboard — SpaceHub" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-0">Host Dashboard</h2>
      <p class="text-muted small mb-0">Welcome back, <%= current_user.display_name %></p>
    </div>
    <%= link_to "+ New Listing", new_host_listing_path, class: "btn btn-warning fw-semibold" %>
  </div>

  <!-- Pending bookings alert -->
  <% if @pending_bookings.any? %>
    <div class="card border-warning bg-warning bg-opacity-10 mb-4">
      <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h6 class="fw-semibold mb-0">
            <i class="bi bi-clock-history text-warning me-2"></i>
            <%= pluralize(@pending_count, "booking") %> awaiting your confirmation
          </h6>
        </div>
        <div class="d-flex flex-column gap-2">
          <% @pending_bookings.each do |booking| %>
            <div class="bg-white rounded p-2 d-flex justify-content-between align-items-center">
              <div>
                <span class="fw-semibold small"><%= booking.user.display_name %></span>
                <span class="text-muted small ms-2">
                  <%= booking.listing.title %> · <%= booking.start_time.strftime("%d %b, %I:%M %p") %>
                </span>
                <span class="fw-bold small ms-2">₹<%= number_with_delimiter(booking.total_price.to_i) %></span>
              </div>
              <div class="d-flex gap-2">
                <%= link_to host_booking_path(booking), class: "btn btn-outline-secondary btn-sm" do %>
                  View
                <% end %>
                <%= button_to host_dashboard_confirm_booking_path,
                      params: { booking_id: booking.id },
                      method: :patch,
                      class: "btn btn-success btn-sm fw-semibold" do %>
                  <i class="bi bi-check-lg me-1"></i> Confirm
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <%= link_to host_listings_path, class: "text-decoration-none" do %>
        <div class="card border-0 bg-dark text-white text-center py-3 hover-shadow" style="cursor:pointer;">
          <div class="h3 fw-bold mb-0"><%= @listings.count %></div>
          <div class="text-secondary small">Listings</div>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to host_bookings_path(status: "pending"), class: "text-decoration-none" do %>
        <div class="card border-0 bg-warning text-dark text-center py-3 hover-shadow" style="cursor:pointer;">
          <div class="h3 fw-bold mb-0"><%= @pending_count %></div>
          <div class="small">Pending</div>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to host_payments_path, class: "text-decoration-none" do %>
        <div class="card border-0 bg-success text-white text-center py-3 hover-shadow" style="cursor:pointer;">
          <div class="h3 fw-bold mb-0">₹<%= number_with_delimiter(@total_earnings.to_i) %></div>
          <div class="small">Earnings</div>
        </div>
      <% end %>
    </div>
    <div class="col-6 col-md-3">
      <%= link_to host_bookings_path, class: "text-decoration-none" do %>
        <div class="card border-0 bg-light text-center py-3 hover-shadow" style="cursor:pointer;">
          <div class="h3 fw-bold mb-0"><%= @recent_bookings.count %></div>
          <div class="text-muted small">Bookings</div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Revenue Chart -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white py-3">
      <h6 class="fw-semibold mb-0"><i class="bi bi-bar-chart me-2"></i>Revenue — Last 6 Months</h6>
    </div>
    <div class="card-body" style="height:220px;">
      <canvas data-controller="revenue-chart"
              data-revenue-chart-labels-value="<%= @revenue_labels.to_json %>"
              data-revenue-chart-data-value="<%= @revenue_data.to_json %>">
      </canvas>
    </div>
  </div>

  <!-- Payment Gateway Status -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
      <h6 class="fw-semibold mb-0"><i class="bi bi-credit-card me-2"></i>Payment Gateways</h6>
      <div class="d-flex gap-2">
        <%= link_to "Payments →", host_payments_path, class: "btn btn-outline-secondary btn-sm" %>
        <%= link_to "Configure", host_gateway_configs_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="row g-0">
        <% [["razorpay", "Razorpay", "UPI / Cards / Net Banking", "warning"],
            ["stripe",   "Stripe",   "International Cards",       "primary"]].each_with_index do |(key, name, desc, color), i| %>
          <div class="col-md-6 <%= 'border-end' if i == 0 %> p-3 d-flex align-items-center gap-3">
            <span class="badge bg-<%= color %> fs-6 px-3 py-2"><%= name %></span>
            <div class="flex-grow-1">
              <p class="mb-0 small text-muted"><%= desc %></p>
            </div>
            <% cfg = @gateway_configs[key] %>
            <% if cfg&.active? %>
              <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
            <% elsif cfg %>
              <span class="badge bg-secondary">Inactive</span>
            <% else %>
              <%= link_to "Set up →", host_gateway_configs_path,
                    class: "badge bg-light text-dark border text-decoration-none" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Listings -->
    <div class="col-lg-6">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-semibold mb-0">Your Listings</h5>
        <%= link_to "View all →", host_listings_path, class: "text-decoration-none small" %>
      </div>
      <% if @listings.any? %>
        <% @listings.each do |listing| %>
          <div class="card border-0 shadow-sm mb-3 hover-shadow"
               data-controller="row-link"
               data-href="<%= host_listing_path(listing) %>"
               data-action="click->row-link#navigate"
               style="cursor:pointer;">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <h6 class="fw-bold mb-1"><%= listing.title %></h6>
                <span class="badge bg-secondary text-capitalize me-1"><%= listing.category %></span>
                <span class="badge bg-<%= listing.status == 'active' ? 'success' : 'secondary' %>"><%= listing.status %></span>
                <p class="text-muted small mb-0 mt-1">
                  ₹<%= number_with_delimiter(listing.price_per_hour.to_i) %>/hr · <%= listing.city %>
                  <% if listing.avg_rating.present? %>
                    · <span class="star-rating">★</span> <%= listing.avg_rating %>
                    <span class="text-muted">(<%= listing.reviews_count %>)</span>
                  <% end %>
                </p>
              </div>
              <div class="d-flex gap-2">
                <%= link_to "Edit",  edit_host_listing_path(listing),          class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Slots", host_listing_availabilities_path(listing), class: "btn btn-outline-secondary btn-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="card text-center py-4">
          <p class="text-muted mb-2">No listings yet.</p>
          <%= link_to "Create your first listing", new_host_listing_path, class: "btn btn-warning btn-sm" %>
        </div>
      <% end %>
    </div>

    <!-- Recent Bookings -->
    <div class="col-lg-6">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-semibold mb-0">Recent Bookings</h5>
        <%= link_to "View all →", host_bookings_path, class: "text-decoration-none small" %>
      </div>
      <% if @recent_bookings.any? %>
        <% @recent_bookings.each do |booking| %>
          <%= link_to host_booking_path(booking), class: "text-decoration-none text-reset" do %>
            <div class="card border-0 shadow-sm mb-2 hover-shadow" style="cursor:pointer;">
              <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                <div>
                  <p class="mb-0 fw-semibold small"><%= booking.user.display_name %></p>
                  <p class="mb-0 text-muted small">
                    <%= booking.listing.title %> · <%= booking.start_time.strftime("%d %b") %>
                    <% if booking.payment_gateway.present? %>
                      · <%= booking.payment_gateway.capitalize %>
                    <% end %>
                  </p>
                </div>
                <div class="text-end">
                  <% status_color = { "confirmed" => "success", "pending" => "warning text-dark",
                                      "completed" => "secondary", "cancelled" => "danger" }[booking.status] || "secondary" %>
                  <span class="badge bg-<%= status_color %> mb-1"><%= booking.status.capitalize %></span>
                  <p class="mb-0 small fw-bold">₹<%= number_with_delimiter(booking.total_price.to_i) %></p>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <p class="text-muted small">No bookings yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Guest Reviews & Feedback -->
  <div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="fw-semibold mb-0">Guest Reviews</h5>
    </div>
    <% if @recent_reviews.any? %>
      <div class="row g-3">
        <% @recent_reviews.each do |review| %>
          <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div>
                    <span class="fw-semibold small"><%= review.user.display_name %></span>
                    <span class="text-muted small ms-2"><%= review.listing.title %></span>
                  </div>
                  <span class="star-rating">
                    <%= "★" * review.rating %><%= "☆" * (5 - review.rating) %>
                  </span>
                </div>
                <p class="text-muted small mb-0 fst-italic">"<%= truncate(review.body, length: 120) %>"</p>
                <p class="text-muted" style="font-size:0.7rem; margin-top:4px; margin-bottom:0;">
                  <%= review.created_at.strftime("%d %b %Y") %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted small">No reviews yet. Completed bookings will show guest feedback here.</p>
    <% end %>
  </div>

</div>
