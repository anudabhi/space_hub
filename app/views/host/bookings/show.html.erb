<% content_for :title, "Booking ##{@booking.id} — Host Dashboard" %>

<div class="container py-4" style="max-width:640px;">
  <div class="mb-3">
    <%= link_to "← All Bookings", host_bookings_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <div class="d-flex align-items-center gap-3 mb-4">
    <h2 class="fw-bold mb-0">Booking #<%= @booking.id %></h2>
    <span class="badge bg-<%= @booking.status == 'confirmed' ? 'success' : @booking.status == 'pending' ? 'warning text-dark' : @booking.status == 'cancelled' ? 'danger' : 'secondary' %> fs-6">
      <%= @booking.status.capitalize %>
    </span>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <h6 class="fw-semibold mb-3">Guest</h6>
      <div class="d-flex align-items-center gap-3">
        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold" style="width:44px;height:44px;">
          <%= @booking.user.display_name.first.upcase %>
        </div>
        <div>
          <p class="mb-0 fw-semibold"><%= @booking.user.display_name %></p>
          <p class="mb-0 text-muted small"><%= @booking.user.email %></p>
          <p class="mb-0 text-muted small"><%= @booking.user.city.presence || "" %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <h6 class="fw-semibold mb-3">Booking Details</h6>
      <dl class="row mb-0">
        <dt class="col-sm-4 text-muted fw-normal">Space</dt>
        <dd class="col-sm-8"><%= link_to @booking.listing.title, host_listing_path(@booking.listing), class: "text-decoration-none fw-semibold" %></dd>
        <dt class="col-sm-4 text-muted fw-normal">Date</dt>
        <dd class="col-sm-8"><%= @booking.start_time.strftime("%d %b %Y") %></dd>
        <dt class="col-sm-4 text-muted fw-normal">Time</dt>
        <dd class="col-sm-8"><%= @booking.start_time.strftime("%I:%M %p") %> – <%= @booking.end_time.strftime("%I:%M %p") %></dd>
        <dt class="col-sm-4 text-muted fw-normal">Duration</dt>
        <dd class="col-sm-8"><%= @booking.hours_duration %> hours</dd>
        <dt class="col-sm-4 text-muted fw-normal">Amount</dt>
        <dd class="col-sm-8 fw-bold">₹<%= number_with_delimiter(@booking.total_price.to_i) %></dd>
        <dt class="col-sm-4 text-muted fw-normal">Payment via</dt>
        <dd class="col-sm-8 text-capitalize"><%= @booking.payment_gateway.presence || "—" %></dd>
      </dl>
    </div>
  </div>

  <!-- Actions -->
  <div class="d-flex gap-2 flex-wrap">
    <% if @booking.status == "pending" %>
      <%= link_to "✓ Confirm Booking", confirm_host_booking_path(@booking),
            data: { turbo_method: :patch, turbo_confirm: "Confirm this booking?" },
            class: "btn btn-success fw-semibold" %>
    <% end %>
    <% if @booking.status == "confirmed" %>
      <%= link_to "Mark as Completed", complete_host_booking_path(@booking),
            data: { turbo_method: :patch, turbo_confirm: "Mark this booking as completed?" },
            class: "btn btn-dark fw-semibold" %>
    <% end %>
  </div>

  <% if @booking.review.present? %>
    <div class="card border-0 bg-light mt-4">
      <div class="card-body p-3">
        <h6 class="fw-semibold mb-2">Guest Review</h6>
        <div class="text-warning mb-1"><%= "★" * @booking.review.rating %><%= "☆" * (5 - @booking.review.rating) %></div>
        <p class="mb-0 small"><%= @booking.review.body %></p>
      </div>
    </div>
  <% end %>
</div>
