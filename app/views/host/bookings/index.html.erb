<% content_for :title, "Bookings — Host Dashboard" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Bookings</h2>
    <%= link_to "← Dashboard", host_root_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <!-- Status tabs -->
  <% statuses = [["all", "All"], ["pending", "Pending"], ["confirmed", "Confirmed"],
                 ["completed", "Completed"], ["cancelled", "Cancelled"]] %>
  <div class="d-flex gap-2 flex-wrap mb-3">
    <% statuses.each do |value, label| %>
      <% active = (params[:status].presence || "all") == value %>
      <% count = value == "all" ? @status_counts.values.sum : @status_counts[value].to_i %>
      <%= link_to host_bookings_path(params.permit(:from, :to).merge(status: value)),
            class: "btn btn-sm #{active ? 'btn-dark' : 'btn-outline-secondary'}" do %>
        <%= label %>
        <span class="badge <%= active ? 'bg-warning text-dark' : 'bg-secondary' %> ms-1"><%= count %></span>
      <% end %>
    <% end %>
  </div>

  <!-- Date range filter -->
  <%= form_with url: host_bookings_path, method: :get, class: "card border-0 shadow-sm mb-4" do |f| %>
    <%= hidden_field_tag :status, params[:status] %>
    <div class="card-body py-3">
      <div class="row g-2 align-items-end">
        <div class="col-sm-4">
          <%= label_tag :from, "From", class: "form-label small mb-1" %>
          <%= date_field_tag :from, params[:from], class: "form-control form-control-sm" %>
        </div>
        <div class="col-sm-4">
          <%= label_tag :to, "To", class: "form-label small mb-1" %>
          <%= date_field_tag :to, params[:to], class: "form-control form-control-sm" %>
        </div>
        <div class="col-sm-4 d-flex gap-2 pt-3">
          <%= f.submit "Apply", class: "btn btn-dark btn-sm px-4" %>
          <% if params[:from].present? || params[:to].present? %>
            <%= link_to "Clear", host_bookings_path(status: params[:status]), class: "btn btn-outline-secondary btn-sm" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Results -->
  <% if @bookings.any? %>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Guest</th>
            <th>Space</th>
            <th>Date & Time</th>
            <th>Duration</th>
            <th>Amount</th>
            <th>Gateway</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @bookings.each do |booking| %>
            <tr data-controller="row-link"
                data-href="<%= host_booking_path(booking) %>"
                data-action="click->row-link#navigate"
                style="cursor:pointer;">
              <td class="text-muted small">#<%= booking.id %></td>
              <td class="fw-semibold small"><%= booking.user.display_name %></td>
              <td class="small text-muted"><%= booking.listing.title.truncate(28) %></td>
              <td class="small"><%= booking.start_time.strftime("%d %b %Y, %I:%M %p") %></td>
              <td class="small"><%= booking.hours_duration %> hr</td>
              <td class="small fw-bold">₹<%= number_with_delimiter(booking.total_price.to_i) %></td>
              <td class="small">
                <% if booking.payment_gateway.present? %>
                  <span class="badge bg-light text-dark border"><%= booking.payment_gateway.capitalize %></span>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td>
                <% status_color = { "confirmed" => "success", "pending" => "warning text-dark",
                                    "completed" => "secondary", "cancelled" => "danger" }[booking.status] || "secondary" %>
                <span class="badge bg-<%= status_color %>"><%= booking.status.capitalize %></span>
              </td>
              <td>
                <div class="d-flex gap-1">
                  <% if booking.status == "pending" %>
                    <%= button_to "Confirm", confirm_host_booking_path(booking),
                          method: :patch, class: "btn btn-success btn-sm" %>
                  <% elsif booking.status == "confirmed" %>
                    <%= button_to "Complete", complete_host_booking_path(booking),
                          method: :patch, class: "btn btn-primary btn-sm" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <p class="text-muted small mt-2">
      Showing <%= pluralize(@bookings.count, "booking") %>
      <% if params[:status].present? && params[:status] != "all" %>
        · status: <strong><%= params[:status] %></strong>
      <% end %>
      <% if params[:from].present? %>
        · from <strong><%= params[:from] %></strong>
      <% end %>
      <% if params[:to].present? %>
        · to <strong><%= params[:to] %></strong>
      <% end %>
    </p>
  <% else %>
    <div class="text-center py-5 text-muted">
      <div class="display-4 mb-3">📅</div>
      <p>No bookings found for the selected filters.</p>
      <%= link_to "Clear filters", host_bookings_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  <% end %>
</div>
